# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://your-user:your-password@your-cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=ovis-demo

# JWT secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-here

# OpenAI API key for Florence AI
OPENAI_API_KEY=sk-your-key-here

# SendGrid API key for email
SENDGRID_API_KEY=SG.your-key-here

# Google Calendar encryption key
CALENDAR_ENCRYPTION_KEY=your-encryption-key-here
